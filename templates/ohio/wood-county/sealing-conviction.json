<script>
async function generatePdfFromTemplate() {
  try {
    const packetData = RecordPathDataBridge.loadPacketData();

    const templateUrl = "./templates/ohio/wood-county/sealing-conviction.json";
    const pdfUrl = "./assets/wood-county-application-for-sealing-295332-conviction.pdf";

    const templateResponse = await fetch(templateUrl, { cache: "no-store" });
    if (!templateResponse.ok) {
      throw new Error("Could not load template JSON.");
    }

    const template = await templateResponse.json();

    const fields = template.fields || template.mappings;

    if (!Array.isArray(fields) || !fields.length) {
      throw new Error("Template JSON must include fields or mappings.");
    }

    const pdfResponse = await fetch(pdfUrl, { cache: "no-store" });
    if (!pdfResponse.ok) {
      throw new Error("Could not load source PDF.");
    }

    const pdfBytes = await pdfResponse.arrayBuffer();

    const { PDFDocument, StandardFonts, rgb } = PDFLib;
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const font = await pdfDoc.embedFont(StandardFonts.Helvetica);
    const boldFont = await pdfDoc.embedFont(StandardFonts.HelveticaBold);
    const pages = pdfDoc.getPages();

    function getValueByPath(obj, path) {
      if (!obj || !path) return "";

      return path.split(".").reduce((acc, key) => {
        if (acc == null) return "";
        if (/^\d+$/.test(key)) return acc[Number(key)];
        return acc[key];
      }, obj) ?? "";
    }

    function formatDate(value) {
      if (!value) return "";

      const date = new Date(value + "T12:00:00");
      if (Number.isNaN(date.getTime())) return value;

      const mm = String(date.getMonth() + 1).padStart(2, "0");
      const dd = String(date.getDate()).padStart(2, "0");
      const yyyy = date.getFullYear();

      return `${mm}/${dd}/${yyyy}`;
    }

    function fitFontSize(text, maxWidth, preferredSize = 11) {
      let size = preferredSize;
      while (size > 7 && font.widthOfTextAtSize(String(text), size) > maxWidth) {
        size -= 0.5;
      }
      return size;
    }

    function drawText(page, value, field) {
      if (value == null || value === "") return;

      const text = String(value);
      const pageHeight = page.getHeight();

      const x = Number(field.x) || 0;
      const yTop = Number(field.y) || 0;
      const width = Number(field.width) || 160;
      const height = Number(field.height) || 20;

      const y = pageHeight - yTop - height + 4;
      const size = fitFontSize(text, width, field.fontSize || 11);

      page.drawText(text, {
        x,
        y,
        size,
        font,
        color: rgb(0, 0, 0),
        maxWidth: width
      });
    }

    function drawSignature(page, value, field) {
      if (value == null || value === "") return;

      const text = String(value);
      const pageHeight = page.getHeight();

      const x = Number(field.x) || 0;
      const yTop = Number(field.y) || 0;
      const width = Number(field.width) || 180;
      const height = Number(field.height) || 24;

      const y = pageHeight - yTop - height + 3;
      const size = fitFontSize(text, width, field.fontSize || 12);

      page.drawText(text, {
        x,
        y,
        size,
        font: boldFont,
        color: rgb(0, 0, 0),
        maxWidth: width
      });
    }

    function drawCheckbox(page, value, field) {
      const checked =
        value === true ||
        value === "true" ||
        value === "yes" ||
        value === "1" ||
        value === "checked";

      if (!checked) return;

      const pageHeight = page.getHeight();

      const x = Number(field.x) || 0;
      const yTop = Number(field.y) || 0;
      const width = Number(field.width) || 12;
      const height = Number(field.height) || 12;

      const y = pageHeight - yTop - height;

      page.drawText("X", {
        x,
        y,
        size: Math.max(10, height),
        font: boldFont,
        color: rgb(0, 0, 0)
      });
    }

    fields.forEach((field) => {
      const pageIndex = Number(field.page) - 1;

      if (pageIndex < 0 || pageIndex >= pages.length) return;

      const page = pages[pageIndex];
      let value = getValueByPath(packetData, field.name);

      if (field.type === "date") {
        value = formatDate(value);
        drawText(page, value, field);
        return;
      }

      if (field.type === "signature") {
        drawSignature(page, value, field);
        return;
      }

      if (field.type === "checkbox") {
        drawCheckbox(page, value, field);
        return;
      }

      drawText(page, value, field);
    });

    const finalPdfBytes = await pdfDoc.save();
    const blob = new Blob([finalPdfBytes], { type: "application/pdf" });
    const url = URL.createObjectURL(blob);

    const link = document.createElement("a");
    link.href = url;
    link.download = "recordpathai-filled-packet.pdf";
    document.body.appendChild(link);
    link.click();
    link.remove();

    setTimeout(() => URL.revokeObjectURL(url), 5000);

  } catch (error) {
    console.error(error);
    alert(error.message);
  }
}

document.addEventListener("DOMContentLoaded", function () {
  const generateBtn = document.getElementById("generateSealingBtn");

  if (generateBtn) {
    generateBtn.addEventListener("click", generatePdfFromTemplate);
  }
});
</script>
